{
  "name": "orders-api",
  "apps": {
    "api": {
      "port": 8080,
      "ingress": "internal",
      "cpu": 0.5,
      "memory": "1Gi",
      "replicas": { "min": 2, "max": 10 },
      "docker": { "file": "./Dockerfile", "context": "." },
      "env": { "LOG_LEVEL": "warn" },
      "secrets": ["STRIPE_KEY"]
    },
    "worker": {
      "port": 8080,
      "ingress": "none",
      "cpu": 0.5,
      "memory": "1Gi",
      "replicas": { "min": 1, "max": 3 },
      "env": {},
      "secrets": []
    }
  },
  "functions": {
    "processor": {
      "env": { "QUEUE": "jobs" },
      "secrets": []
    }
  },
  "database": { "size": "medium", "storage_gb": 32, "public_access": false },
  "storage": { "containers": ["uploads"], "public_access": false }
}
