{
  "name": "billing",
  "apps": {
    "gateway": {
      "ingress": { "external": true, "target_port": 3000, "transport": "http2", "allow_insecure": false },
      "replicas": { "min": 1, "max": 3 },
      "containers": {
        "web": {
          "cpu": 0.5,
          "memory": "1Gi",
          "docker": { "file": "./web/Dockerfile" },
          "env": {},
          "secrets": []
        },
        "proxy": {
          "cpu": 0.25,
          "memory": "0.5Gi",
          "env": { "MODE": "sidecar" },
          "secrets": []
        }
      }
    }
  }
}
