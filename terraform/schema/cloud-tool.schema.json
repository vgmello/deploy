{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vgmello/deploy/terraform/schema/cloud-tool.schema.json",
  "title": "cloud-tool manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "anyOf": [
    {
      "required": [
        "app"
      ]
    },
    {
      "required": [
        "apps"
      ]
    },
    {
      "required": [
        "functions"
      ]
    },
    {
      "required": [
        "static_sites"
      ]
    }
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,29}$"
    },
    "app": {
      "$ref": "#/$defs/app"
    },
    "apps": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9-]{0,29}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/app"
      }
    },
    "functions": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9-]{0,29}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/function"
      }
    },
    "static_sites": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9-]{0,29}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/static_site"
      }
    },
    "database": {
      "$ref": "#/$defs/database"
    },
    "storage": {
      "$ref": "#/$defs/storage"
    },
    "environments": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9]{1,15}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/overlay"
      }
    }
  },
  "$defs": {
    "app": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,29}$"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "ingress": {
          "oneOf": [
            {
              "enum": [
                "public",
                "internal",
                "none"
              ]
            },
            {
              "$ref": "#/$defs/ingress"
            }
          ]
        },
        "cpu": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "memory": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?Gi$"
        },
        "replicas": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 0
            },
            "max": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "docker": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string"
            },
            "context": {
              "type": "string"
            }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "containers": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9-]{0,29}$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/container"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "containers"
            ]
          },
          "then": {
            "properties": {
              "cpu": false,
              "memory": false,
              "docker": false,
              "env": false,
              "secrets": false
            }
          }
        }
      ]
    },
    "function": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,29}$"
        },
        "docker": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string"
            },
            "context": {
              "type": "string"
            }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        }
      }
    },
    "static_site": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,29}$"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "postgres",
            "sqlserver"
          ]
        },
        "size": {
          "enum": [
            "small",
            "medium",
            "large"
          ]
        },
        "storage_gb": {
          "type": "integer",
          "minimum": 32,
          "maximum": 16384
        },
        "public_access": {
          "type": "boolean"
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "containers": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]{1,61})?[a-z0-9]$"
          }
        },
        "public_access": {
          "type": "boolean"
        }
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app": {
          "$ref": "#/$defs/app"
        },
        "apps": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/app"
          }
        },
        "functions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/function"
          }
        },
        "static_sites": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/static_site"
          }
        },
        "database": {
          "$ref": "#/$defs/database"
        },
        "storage": {
          "$ref": "#/$defs/storage"
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "external": {
          "type": "boolean"
        },
        "target_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "exposed_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "transport": {
          "enum": [
            "auto",
            "http",
            "http2",
            "tcp"
          ]
        },
        "allow_insecure": {
          "type": "boolean"
        }
      }
    },
    "container": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "memory": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?Gi$"
        },
        "docker": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string"
            },
            "context": {
              "type": "string"
            }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "required": [
          "app",
          "apps"
        ]
      }
    }
  ]
}
